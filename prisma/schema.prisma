generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// --- CORE ---

model Church {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique // Ej: mi-iglesia (para el portal publico)
  domain      String?  @unique // Ej: www.miiglesia.com (dominio personalizado futuro)
  description String?
  logo        String?
  created_at  DateTime @default(now())
  
  // Relaciones
  members     UserChurch[] // Usuarios administrativos
  events      Event[]
  sermons     Sermon[]
  ministries  Ministry[]
  songs       Song[]
  directory   Member[] // Miembros regulares
}

enum EventRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum EventVisibility {
  PUBLIC
  PRIVATE
  MINISTRY
}

model User {
  id            String   @id @default(uuid()) // Creado localmente o vía NextAuth
  name          String
  email         String   @unique
  password_hash String   // Para login por credenciales en NextAuth
  created_at    DateTime @default(now())

  // Un usuario puede pertenecer a múltiples iglesias
  churches      UserChurch[]
}

// Tabla pivote con roles (Manejo de Permisos multi-tenant)
model UserChurch {
  id        String @id @default(uuid())
  userId    String
  church_id String
  role      Role   @default(MEMBER) // ADMIN, LEADER, MEMBER

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  church    Church @relation(fields: [church_id], references: [id], onDelete: Cascade)

  @@unique([userId, church_id]) // Un usuario solo tiene un registro por iglesia
}

enum Role {
  ADMIN
  LEADER
  MEMBER
}

// --- GESTIÓN DE CONTENIDO ---

model Event {
  id                  String   @id @default(uuid())
  church_id           String
  title               String
  description         String?
  location            String?
  start_date          DateTime
  end_date            DateTime
  
  // Recurrencia
  recurrence          EventRecurrence @default(NONE)
  recurrence_end_date DateTime?
  
  // Visibilidad y Segmentación
  visibility          EventVisibility @default(PUBLIC)
  ministry_id         String?

  created_at          DateTime @default(now())
  
  church              Church   @relation(fields: [church_id], references: [id], onDelete: Cascade)
  ministry            Ministry? @relation(fields: [ministry_id], references: [id], onDelete: SetNull)
}

model Sermon {
  id               String   @id @default(uuid())
  church_id        String
  title            String
  preacher         String
  youtube_video_id String
  date             DateTime
  series           String?
  created_at       DateTime @default(now())
  
  church           Church   @relation(fields: [church_id], references: [id], onDelete: Cascade)
}

model Ministry {
  id            String   @id @default(uuid())
  church_id     String
  name          String
  description   String?
  leader_name   String?
  coleader_name String?
  parent_id     String?  // Si tiene un padre, esto es un sub-departamento
  created_at    DateTime @default(now())
  
  church        Church   @relation(fields: [church_id], references: [id], onDelete: Cascade)

  // Autorelación para departamentos
  parent        Ministry?  @relation("MinistryHierarchy", fields: [parent_id], references: [id], onDelete: SetNull)
  departments   Ministry[] @relation("MinistryHierarchy")

  // Eventos exclusivos de este ministerio
  events        Event[]

  // Integrantes del ministerio
  members       MinistryMember[]
}

model Member {
  id         String   @id @default(uuid())
  church_id  String
  first_name String
  last_name  String
  email      String?
  phone      String?
  birth_date DateTime?
  created_at DateTime @default(now())

  church     Church   @relation(fields: [church_id], references: [id], onDelete: Cascade)
  ministries MinistryMember[]
}

model MinistryMember {
  id          String   @id @default(uuid())
  ministry_id String
  member_id   String
  role        String   @default("MEMBER") // Puede ser LEADER, COLEADER, MEMBER
  joined_at   DateTime @default(now())

  ministry    Ministry @relation(fields: [ministry_id], references: [id], onDelete: Cascade)
  member      Member   @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@unique([ministry_id, member_id])
}

model Song {
  id          String   @id @default(uuid())
  church_id   String
  title       String
  lyrics      String?  @db.Text
  youtube_url String?
  created_at  DateTime @default(now())
  
  church      Church   @relation(fields: [church_id], references: [id], onDelete: Cascade)
}
